# Per-machine installer backups — not portable, regenerated on every install/uninstall.
.install-backups/
.uninstall-backups/

# Python
__pycache__/
*.py[cod]

# Editors / OS
*.swp
*~
.DS_Store

# Memory store: per-entry memories are local-only; keep the infra scaffolding tracked.
# (_tags.md, _tag_links.md = underscore-prefixed infra; _review_game.py is .py, untouched.)
memory/*.md
!memory/_*.md
