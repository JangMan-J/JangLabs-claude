{
  "_comment": "Merged into ~/.claude/settings.json by claude/agent-harness.py (install subcommand) — hooks only; permissions (allow/deny, defaultMode, bypass flags) are NEVER touched. Existing keys are preserved; each hook command not already registered is added at per-command granularity within its (event, matcher) block, so a hook can be added INTO an existing matcher block, a command already present under the SAME matcher is never duplicated, and the same command MAY be registered under two DIFFERENT matchers of one event (e.g. memory-recall.sh under the native-tools matcher AND the Context7 MCP-regex matcher). Grouping is therefore free — a hook no longer needs its own group object (the old jq merge deduped whole groups by their first command, which is why lab-scope.sh used to sit alone; that workaround is gone). Hook command dirs use the literal 'HOOKS_DIR/' placeholder; agent-harness.py rewrites each to $HOME/.claude/hooks at install time, so this fragment is host-agnostic.",
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "HOOKS_DIR/system-fingerprint.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "HOOKS_DIR/memory-review-offer.sh",
            "timeout": 3
          },
          {
            "type": "command",
            "command": "HOOKS_DIR/lab-scope.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "HOOKS_DIR/bash-idiom-guard.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "HOOKS_DIR/forbidden-files-guard.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "HOOKS_DIR/config-drift-guard.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "HOOKS_DIR/memory-write-context.sh",
            "timeout": 5
          },
          {
            "type": "command",
            "command": "HOOKS_DIR/memory-write-guard.sh",
            "timeout": 10
          }
        ]
      },
      {
        "matcher": "Bash|Read|Edit|Write|MultiEdit|WebFetch|WebSearch",
        "hooks": [
          {
            "type": "command",
            "command": "HOOKS_DIR/memory-recall.sh",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "mcp__plugin_context7_context7__.*",
        "hooks": [
          {
            "type": "command",
            "command": "HOOKS_DIR/memory-recall.sh",
            "timeout": 5
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "HOOKS_DIR/syntax-check-touched.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": "HOOKS_DIR/memory-catalog-refresh.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "HOOKS_DIR/memory-base-floor.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
